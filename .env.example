# PostgreSQL Configuration (only supported database per ADR-0001)
DATABASE_URL_POSTGRES="postgresql://postgres:postgres@localhost:5432/pilingtrack?schema=public"

# Session Security
SESSION_SECRET="dev-only-change-me-must-be-at-least-32-characters-long"

# Database Logging (set to true for debugging)
DATABASE_LOG_QUERIES="false"

# Multi-Tenant Configuration (false | single | multi)
MULTI_TENANT_MODE="false"
DEFAULT_TENANT_ID="default"

# Sentry (optional)
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT="pilingtrack"
SENTRY_AUTH_TOKEN=""

# Redis (required for production features: rate limiting, caching, event bus)
REDIS_URL="redis://localhost:6379"

# Encryption (required for production — 32 bytes hex)
ENCRYPTION_KEY=""
