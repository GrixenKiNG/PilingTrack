    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pdfkit": "^0.18.0",
    "pino": "^10.3.1",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.73.1",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.1",
