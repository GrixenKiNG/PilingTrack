{
  "name": "nextjs_tailwind_shadcn_ts",
  "version": "2.2.1",
  "private": true,
  "scripts": {
    "predev": "node scripts/kill-port.js 3000",
    "dev": "npx tsx scripts/validate-env.ts && next dev -p 3000",
    "build": "npx tsx scripts/validate-env.ts && npm run db:generate && next build && node scripts/copy-standalone-assets.js",
    "prestart": "node scripts/kill-port.js 3000",
    "start": "npx tsx scripts/validate-env.ts && node .next/standalone/server.js",
    "validate:env": "npx tsx scripts/validate-env.ts",
    "lint": "eslint . && node scripts/check-text-integrity.js",
    "typecheck": "npm run build && tsc --noEmit",
    "test:smoke:auth-access": "npm run build && node scripts/smoke-auth-access.js",
    "openapi:generate": "npx tsx scripts/generate-openapi.ts",
    "postgres:setup": "node scripts/setup-postgres.js",
    "postgres:check-rules": "node scripts/check-postgres-rules.js",
    "postgres:apply-hardening": "npx tsx scripts/apply-postgres-hardening.ts",
    "seed": "npm run db:seed",
    "test:interactive": "npx tsx scripts/test-runner.ts",
    "postgres:explain-analyze": "npx tsx scripts/explain-analyze.ts",
    "postgres:setup-partitioning": "npx tsx scripts/setup-partitioning.ts",
    "test:load": "npx k6 run scripts/load-test.js",
    "test:load:spike": "npx k6 run scripts/load-test.js --vus 100 --duration 30s",
    "verify": "npm run lint && npm run typecheck && npm run test:unit && npm run test:smoke:auth-access",
    "cleanup:local": "powershell -ExecutionPolicy Bypass -File scripts/cleanup-local-artifacts.ps1",
    "agents:test": "npx tsx agents/run-agents.ts",
    "agents:test:quick": "npx tsx agents/run-agents.ts --quick",
    "test:e2e": "npx playwright test",
    "test:coverage": "vitest run --coverage",
    "test:e2e:ui": "npx playwright test --ui",
    "test:unit": "vitest run",
    "test:contract": "vitest run tests/contract",
    "test:integration": "vitest run tests/integration",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test": "npm run test:unit && npm run test:e2e",
    "worker:outbox": "npx tsx src/workers/outbox-worker.ts",
    "worker:projection": "npx tsx src/workers/projection-worker.ts",
    "worker:pdf": "npx tsx src/workers/pdf-worker.ts",
    "worker:all": "npx tsx src/workers/unified-worker.ts",
    "postinstall": "npm run db:generate",
    "db:push": "prisma db push",
    "db:generate": "prisma generate && node scripts/patch-postgres-client.js",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "npx tsx prisma/seed.ts",
    "check:text-integrity": "node scripts/check-text-integrity.js",
    "stage:doctor": "node scripts/stage-doctor.js",
    "stage:postgres:up": "powershell -ExecutionPolicy Bypass -File scripts/start-stage-postgres.ps1",
    "stage:postgres:down": "docker compose -f docker-compose.production.yml down",
    "stage:postgres:cutover": "node scripts/run-stage-postgres-cutover.js",
    "test:load:smoke": "node scripts/quick-load-test.js",
    "test:load:stress": "node scripts/stress-test-100.js",
    "docker:build:prod": "docker build -f Dockerfile.prod -t ghcr.io/pilingtrack/pilingtrack:${npm_package_version:-latest} .",
    "helm:lint": "helm lint infra/helm/pilingtrack",
    "helm:template:staging": "helm template pilingtrack-staging infra/helm/pilingtrack -f infra/helm/pilingtrack/values-staging.yaml",
    "helm:template:prod": "helm template pilingtrack-prod infra/helm/pilingtrack -f infra/helm/pilingtrack/values-prod.yaml",
    "argocd:apply": "kubectl apply -f infra/argocd/",
    "db:indexes": "npx prisma db execute --file prisma/indexes.sql",
    "db:apply-ddl": "npx tsx scripts/apply-full-ddl.ts",
    "test:redis:stress": "node scripts/redis-stress-test.js",
    "test:redis:cache": "node scripts/test-redis-cache.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1036.0",
    "@opentelemetry/api": "^1.9.1",
