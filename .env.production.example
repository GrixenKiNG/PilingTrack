# For host-machine runtime. For docker-compose use .env.docker.example with host "postgres".
DATABASE_PROVIDER="postgres"
DATABASE_URL_POSTGRES="postgresql://postgres:postgres@localhost:5432/pilingtrack?schema=public"
POSTGRES_DB="pilingtrack"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="replace-with-a-strong-password"
SESSION_SECRET="replace-with-a-long-random-secret"
# HMAC secret for hashing device API keys. REQUIRED in production (fail-closed).
# Generate: openssl rand -base64 48
DEVICE_KEY_LOOKUP_SECRET="replace-with-a-long-random-secret"
# HMAC secret for PIN lookup hashing. REQUIRED in production.
# WARNING: rotating invalidates ALL existing PIN logins. Generate: openssl rand -base64 48
PIN_LOOKUP_SECRET="replace-with-a-long-random-secret"
DATABASE_LOG_QUERIES="false"
MULTI_TENANT_MODE="false"
DEFAULT_TENANT_ID="default"
SENTRY_ORG=""
SENTRY_PROJECT="pilingtrack"
SENTRY_AUTH_TOKEN=""

# Redis (for WS Pub/Sub)
# Redis password (required, shared by both instances).
# Generate: openssl rand -hex 32
REDIS_PASSWORD="replace-with-openssl-rand-hex-32"
# State instance: rate-limit, queues, pub/sub. noeviction policy.
REDIS_URL="redis://default:${REDIS_PASSWORD}@localhost:6380"
# Cache instance: response cache, API cache. allkeys-lru policy.
# Leave unset on a single-Redis deployment — code falls back to REDIS_URL.
REDIS_URL_CACHE="redis://default:${REDIS_PASSWORD}@localhost:6381"

# WebSocket
WS_URL="ws://localhost:3001"
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# S3 Storage (optional — AWS S3, MinIO, R2, Spaces)
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="pilingtrack-reports"

# OpenTelemetry (optional — Jaeger, Tempo, Honeycomb)
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_SERVICE_NAME="pilingtrack"
OTEL_TRACES_SAMPLER_ARG="0.1"
