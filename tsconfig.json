{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "examples",
    "src/components/edutrack",
    "agents",
    "e2e",
    "playwright.config.ts",
    "zai-provider-extension",
    "scripts",
    "tests",
    "vitest.config.ts",
    "check-users.ts",
    "fix-admin.ts",
    "test-comprehensive.ts",
    "test-comprehensive-v2.ts",
    "api-test-suite.ts",
    "extended-api-test.ts",
    "setup-test-users.ts",
    "check-test-users.ts",
    "comprehensive-test-suite.ts",
    "prisma/seed-test-data.ts"
  ]
}
