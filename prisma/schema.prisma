generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/postgres-client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TENANTS — Multi-tenant isolation
// ============================================================

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(true)
  maxUsers    Int      @default(10)
  plan        String   @default("free")

  // Billing & Subscription
  billingEmail String?
  stripeCustomerId String?
  subscriptionStatus String @default("inactive") // inactive, trial, active, past_due, canceled
  trialEndsAt DateTime?
  subscriptionEndsAt DateTime?
  lastBillingAt DateTime?
  monthlyFee    Float    @default(0)
  currency      String   @default("RUB")

  // Usage tracking
  currentUsers  Int      @default(0)
  currentSites  Int      @default(0)
  storageUsedMB Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  sites       Site[]
  invoices    TenantInvoice[]

  @@index([slug])
  @@index([isActive])
  @@index([subscriptionStatus])
}

// Tenant Invoices — Billing history
model TenantInvoice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoiceNumber String @unique
  periodStart DateTime
  periodEnd   DateTime
  amount      Float
  currency    String   @default("RUB")
  status      String   @default("pending") // pending, paid, overdue, canceled
  paidAt      DateTime?
  stripeInvoiceId String?

  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([status])
  @@index([periodStart])
}

// ============================================================
// USERS — 4 roles: ADMIN, DISPATCHER, OPERATOR, ASSISTANT
// ============================================================

model User {
  id         String   @id @default(cuid())
  tenantId   String?
  email      String   @unique
  password   String   @default("")
  // Stores the bcrypt(PIN) — used for the final verify step.
  pin        String?  @unique
  // Deterministic HMAC(PIN, PIN_LOOKUP_SECRET). Used as an O(1) index for
  // PIN auth: look up the single candidate user, then bcrypt-verify against
  // `pin`. Avoids a full table scan on every PIN login.
  pinLookup  String?  @unique
  name       String
  phone      String   @default("")
  role       String   @default("OPERATOR")
  isActive   Boolean  @default(true)
  timezone   String   @default("Europe/Moscow")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  reports    Report[]
  sites      UserSiteAssignment[]
  crew       Crew?    @relation("CrewOperator")
  feedbackReads FeedbackEventRead[]

  @@index([email])
}

// ============================================================
// EQUIPMENT PARK
// ============================================================

model Equipment {
  id          String   @id @default(cuid())
  name        String
  model       String   @default("")
  qty         Int      @default(1)
  isActive    Boolean  @default(true)
  description String   @default("")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  crews       Crew[]
  reports     Report[] @relation("ReportEquipment")
  deviceKeys  DeviceKey[]

  @@index([isActive])
}

// ============================================================
// DEVICE KEYS — IoT telemetry authentication
// Plaintext key is shown to the operator exactly once at provisioning
// and never stored; only `keyHash` (HMAC-SHA256 with DEVICE_KEY_LOOKUP_SECRET)
// is persisted, so DB read access alone cannot impersonate a device.
// ============================================================
model DeviceKey {
  id           String   @id @default(cuid())
  keyHash      String   @unique
  name         String   // operator-facing label (e.g. "Rig 4 — North site MQTT")
  tenantId     String?
  equipmentId  String
  siteId       String?
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  createdById  String?
  lastUsedAt   DateTime?

  equipment    Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
  @@index([tenantId])
  @@index([revoked])
}

// ============================================================
// SITES
// ============================================================

model Site {
  id               String    @id @default(cuid())
  tenantId         String?
  name             String
  isActive         Boolean   @default(true)
  plannedPiles     Int       @default(0)
  plannedDrilling  Float     @default(0)
  status           String    @default("ACTIVE")
  completionDate   DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  fields           PileField[]
  pilePlans        SitePilePlan[]
  drillingPlans    SiteDrillingPlan[]
  users            UserSiteAssignment[]
  reports          Report[]
  crews            Crew[]

  @@index([tenantId])
  @@index([isActive])
  @@index([tenantId, isActive])
}

// Site pile plan: grade → count × meters per unit → auto total meters
model SitePilePlan {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pileGradeId   String
  pileGrade     PileGrade @relation(fields: [pileGradeId], references: [id], onDelete: Cascade)
  count         Int      @default(0)
  metersPerUnit Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([siteId])
}

// Site drilling plan: diameter → count × meters per unit → auto total meters
model SiteDrillingPlan {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  diameter      Float    @default(0)
  count         Int      @default(0)
  metersPerUnit Float    @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([siteId])
}

model PileField {
  id        String   @id @default(cuid())
  name      String
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clusters  Cluster[]

  @@index([siteId])
}

model Cluster {
  id        String   @id @default(cuid())
  name      String
  fieldId   String
  field     PileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pickets   Picket[]

  @@index([fieldId])
}

model Picket {
  id        String   @id @default(cuid())
  name      String
  clusterId String
  cluster   Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  piles     PileWork[]
  drillings LeaderDrilling[]

  @@index([clusterId])
}

// ============================================================
// CREWS — with named assistants
// ============================================================

model Crew {
  id              String   @id @default(cuid())
  name            String   @default("")
  isActive        Boolean  @default(true)
  operatorId      String   @unique
  equipmentId     String
  siteId          String

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  operator        User       @relation("CrewOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
  site            Site       @relation(fields: [siteId], references: [id], onDelete: Restrict)
  reports         Report[]
  assistants      CrewAssistant[]

  @@index([operatorId])
  @@index([equipmentId])
  @@index([siteId])
  @@index([isActive])
}

// Named crew assistants (ФИО помощника)
model CrewAssistant {
  id        String   @id @default(cuid())
  crewId    String
  crew      Crew     @relation(fields: [crewId], references: [id], onDelete: Cascade)
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([crewId])
}

// ============================================================
// USER <-> SITE ACCESS
// ============================================================

model UserSiteAssignment {
  id        String   @id @default(cuid())
  userId    String
  siteId    String
  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  site      Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, siteId])
  @@index([userId])
  @@index([siteId])
}

// ============================================================
// REPORTS
// ============================================================

model Report {
  id           String   @id @default(cuid())
  tenantId     String?
  reportId     String   @unique
  userId       String
  crewId       String?
  equipmentId  String?
  siteId       String
  date         String
  shiftType    String   @default("DAY")
  shiftStart   String?
  shiftEnd     String?
  status       String   @default("draft")
  version      Int      @default(1)
  vectorClock  Json?    // Vector clock for causal ordering (new in v3)
  lastEditedById   String?
  lastEditedByName String?
  lastEditedByRole String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  site         Site  @relation(fields: [siteId], references: [id], onDelete: Cascade)
  crew         Crew? @relation(fields: [crewId], references: [id], onDelete: SetNull)
  equipment    Equipment? @relation("ReportEquipment", fields: [equipmentId], references: [id], onDelete: SetNull)

  downtimes    ReportDowntime[]
  piles        PileWork[]
  drillings    LeaderDrilling[]

  @@index([tenantId])
  @@index([tenantId, updatedAt])
  @@index([userId, date])
  @@index([siteId, date])
  @@index([status])
  @@index([crewId])
  @@index([equipmentId])
  @@unique([userId, siteId, date], name: "unique_user_site_date")
}

// ============================================================
// REPORT VERSIONS — Immutable snapshots for audit/legal
// ============================================================

model ReportVersion {
  id        String   @id @default(cuid())
  reportId  String
  version   Int
  data      Json
  actorId   String
  createdAt DateTime @default(now())

  @@unique([reportId, version])
  @@index([reportId])
  @@index([createdAt])
}

// ============================================================
// REPORT AUDIT — Immutable diff tracking for compliance
// ============================================================

model ReportAudit {
  id          String   @id @default(cuid())
  reportId    String
  actorId     String
  actorName   String?
  actorRole   String?
  action      String   // created, updated, submitted, deleted
  diff        Json?    // { added: {...}, removed: {...}, changed: {...} }
  beforeHash  String?  // Hash of previous state for integrity verification
  afterHash   String?  // Hash of new state for integrity verification
  ipAddress   String?
  userAgent   String?
  requestId   String?  // Correlation ID from request
  createdAt   DateTime @default(now())

  @@index([reportId])
  @@index([actorId, createdAt])
  @@index([createdAt])
}

// ============================================================
// IIOT TELEMETRY — Sensor data ingestion
// ============================================================

model TelemetryRecord {
  id          String   @id @default(cuid())
  type        String   // pile_strike, drilling_depth, equipment_gps, cycle_time, pressure, vibration, temperature
  equipmentId String
  siteId      String?
  value       Float
  unit        String?
  latitude    Float?
  longitude   Float?
  metadata    Json?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([equipmentId, timestamp])
  @@index([siteId, timestamp])
  @@index([type, timestamp])
}

// ============================================================
// OUTBOX — Reliable event publishing (transactional outbox)
// ============================================================

model OutboxEvent {
  id          String   @id @default(cuid())
  type        String   // Domain event type
  aggregateId String
  aggregateType String
  payload     Json     // Event payload
  published   Boolean  @default(false)
  // "projected" tracks the READ-side consumer (CQRS projections). Separating
  // it from `published` lets the outbox publisher and the projection worker
  // advance independently instead of racing to mark the same row consumed.
  projected   Boolean  @default(false)
  attempts    Int      @default(0)
  lastError   String?
  occurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  publishedAt DateTime?
  // Earliest time a retry should be attempted. Used by the outbox publisher
  // to implement exponential backoff with jitter.
  nextRetryAt DateTime?

  @@index([published, nextRetryAt])
  @@index([published, createdAt])
  @@index([projected, createdAt])
  @@index([aggregateId, aggregateType])
}

// ============================================================
// CQRS READ PROJECTIONS — Denormalized tables for fast queries
// ============================================================

model ReportAnalytics {
  id            String   @id @default(cuid())
  reportId      String   @unique
  siteId        String
  userId        String
  tenantId      String?
  status        String   @default("draft")
  totalPiles    Int      @default(0)
  totalDrilling Float    @default(0)
  totalDowntime Float    @default(0)
  lastEventAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([siteId])
  @@index([userId])
  @@index([tenantId])
  @@index([status])
}

model SiteDailySummary {
  id            String   @id @default(cuid())
  siteId        String
  date          String   // YYYY-MM-DD
  totalPiles    Int      @default(0)
  totalDrilling Float    @default(0)
  totalDowntime Float    @default(0)
  reportCount   Int      @default(0)
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@unique([siteId, date])
  @@index([siteId])
  @@index([date])
}

// ============================================================
// CQRS READ PROJECTIONS — Advanced Read Models
// ============================================================

// Report-level aggregated stats for fast dashboard queries
model ReportStats {
  id              String   @id @default(cuid())
  reportId        String   @unique
  siteId          String
  userId          String
  tenantId        String?
  date            String   // YYYY-MM-DD
  shiftType       String   // DAY | NIGHT

  // Aggregated metrics
  totalPiles      Int      @default(0)
  totalDrilling   Float    @default(0)
  totalDowntime   Float    @default(0)
  downtimeCount   Int      @default(0)
  pileGradeCount  Int      @default(0)
  drillingCount   Int      @default(0)

  // Performance metrics
  pilesPerHour    Float?   // Computed from shift duration
  drillingPerHour Float?

  // Downtime breakdown (top reason)
  topDowntimeReasonId   String?
  topDowntimeDuration   Float?

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())

  @@index([siteId, date])
  @@index([userId, date])
  @@index([tenantId])
  @@index([date])
}

// Operator performance — daily aggregation per user
model OperatorPerformance {
  id              String   @id @default(cuid())
  userId          String
  userName        String   // Denormalized
  siteId          String
  siteName        String   // Denormalized
  tenantId        String?
  date            String   // YYYY-MM-DD

  // Production metrics
  totalPiles      Int      @default(0)
  totalDrilling   Float    @default(0)
  totalDowntime   Float    @default(0)
  reportCount     Int      @default(0)

  // Efficiency
  avgPilesPerReport   Float?
  avgDrillingPerReport Float?
  avgDowntimePerReport Float?

  // Downtime ratio
  downtimeRatio   Float    @default(0)  // downtime / shift duration

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([userId, siteId, date])
  @@index([userId, date])
  @@index([siteId, date])
  @@index([tenantId])
}

// Downtime summary — aggregated by reason, site, date
model DowntimeSummary {
  id              String   @id @default(cuid())
  siteId          String
  date            String   // YYYY-MM-DD
  reasonId        String
  reasonName      String   // Denormalized
  tenantId        String?

  totalDuration   Float    @default(0)
  occurrenceCount Int      @default(0)
  affectedReports Int      @default(0)

  // Percentage of total site downtime for that day
  percentageOfTotal Float  @default(0)

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([siteId, date, reasonId])
  @@index([siteId, date])
  @@index([reasonId])
  @@index([tenantId])
}

// Site weekly summary — for trend charts
model SiteWeeklyTrend {
  id              String   @id @default(cuid())
  siteId          String
  tenantId        String?
  weekStart       String   // YYYY-MM-DD (Monday)
  weekEnd         String   // YYYY-MM-DD (Sunday)

  // Daily breakdown stored as JSON
  dailyMetrics    Json     // [{date, piles, drilling, downtime}]

  totalPiles      Int      @default(0)
  totalDrilling   Float    @default(0)
  totalDowntime   Float    @default(0)
  reportCount     Int      @default(0)

  // Trend direction
  pilesTrend      String?  // UP | DOWN | STABLE
  drillingTrend   String?
  downtimeTrend   String?

  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([siteId, weekStart])
  @@index([siteId, weekStart])
  @@index([tenantId])
}

// ============================================================
// PILE WORK
// ============================================================

model PileWork {
  id           String   @id @default(cuid())
  reportId     String
  picketId     String?
  pileGradeId  String
  count        Int

  createdAt    DateTime @default(now())

  report       Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  picket       Picket?  @relation(fields: [picketId], references: [id])
  pileGrade    PileGrade @relation(fields: [pileGradeId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@index([picketId])
  @@index([pileGradeId])
}

// ============================================================
// LEADER DRILLING
// ============================================================

model LeaderDrilling {
  id        String   @id @default(cuid())
  reportId  String
  picketId  String?
  typeId    String
  count     Int      @default(1)
  metersPerUnit Float @default(0)
  meters    Float

  createdAt DateTime @default(now())

  report    Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)
  picket    Picket?      @relation(fields: [picketId], references: [id])
  type      DrillingType @relation(fields: [typeId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@index([picketId])
  @@index([typeId])
}

// ============================================================
// DOWNTIME
// ============================================================

model ReportDowntime {
  id        String  @id @default(cuid())
  reportId  String
  reasonId  String
  duration  Float
  comment   String?

  createdAt DateTime @default(now())

  report    Report          @relation(fields: [reportId], references: [id], onDelete: Cascade)
  reason    DowntimeReason  @relation(fields: [reasonId], references: [id], onDelete: Restrict)

  @@index([reportId])
  @@index([reasonId])
}

// ============================================================
// DICTIONARIES
// ============================================================

model PileGrade {
  id        String  @id @default(cuid())
  name      String
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  piles     PileWork[]
  plans     SitePilePlan[]
}

model DrillingType {
  id        String  @id @default(cuid())
  name      String
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  drillings LeaderDrilling[]
}

model DowntimeReason {
  id        String  @id @default(cuid())
  name      String
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  downtimes ReportDowntime[]
}

// ============================================================
// TELEGRAM CONFIG
// ============================================================

model TelegramConfig {
  id        String  @id @default(cuid())
  label     String
  botToken  String
  chatId    String
  enabled   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// FEEDBACK / INDUSTRIAL EVENT LOOP
// ============================================================

model FeedbackEvent {
  id         String   @id @default(cuid())
  level      String   @default("info")
  priority   String   @default("MEDIUM")
  scope      String
  action     String
  title      String
  message    String
  audience   String   @default("OPERATIONS")
  actorId    String?
  actorName  String?
  actorRole  String?
  targetId   String?
  requestId  String?
  metadata   Json?

  createdAt  DateTime @default(now())
  reads      FeedbackEventRead[]

  @@index([createdAt])
  @@index([scope, createdAt])
  @@index([actorId, createdAt])
  @@index([audience, createdAt])
  @@index([level, createdAt])
  @@index([priority, createdAt])
}

model FeedbackEventRead {
  id             String        @id @default(cuid())
  eventId         String
  userId          String
  readAt          DateTime?
  acknowledgedAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  event           FeedbackEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, readAt])
  @@index([userId, acknowledgedAt])
}

// ============================================================
// AUDIT LOG — Immutable, append-only
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  entity      String   // e.g. "Report", "User", "Site"
  action      String   // e.g. "created", "updated", "deleted", "submitted"
  entityId    String   // ID of the affected entity
  before      Json?    // Previous state (null for create)
  after       Json?    // New state (null for delete)
  userId      String?  // Actor
  userName    String?  // Denormalized for fast reads
  userRole    String?  // Denormalized
  tenantId    String?  // Multi-tenant isolation
  requestId   String?  // Correlation ID
  ipAddress   String?  // Client IP
  userAgent   String?  // Client info
  timestamp   DateTime @default(now())

  // Immutable guarantee: no UPDATE, only INSERT
  // Soft-delete protection via application layer

  @@index([entity, entityId])
  @@index([userId, timestamp])
  @@index([tenantId, timestamp])
  @@index([action, timestamp])
  @@index([timestamp])
}

// ============================================================
// IDEMPOTENCY KEYS — Prevent duplicate API requests
// ============================================================

model IdempotencyKey {
  id          String   @id @default(cuid())
  key         String   // Client-provided unique key
  scope       String   // API endpoint / operation scope
  status      String   @default("processing") // processing | completed | failed
  result      Json?    // Cached response
  error       String?  // Error message if failed
  statusCode  Int?     // HTTP status code for errors
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@unique([scope, key])
  @@index([scope, key])
  @@index([expiresAt])
  @@index([status, createdAt])
}

// ============================================================
// DEVICE SYNC STATE — Per-device sync tracking
// ============================================================

model DeviceSyncState {
  id            String   @id @default(cuid())
  deviceId      String   @unique
  tenantId      String?
  userId        String?
  lastSyncAt    DateTime @default(now())
  syncStatus    String   @default("idle") // idle, syncing, failed
  lastError     String?
  changesSent   Int      @default(0)
  changesRecv   Int      @default(0)
  lastVectorClock Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([syncStatus])
  @@index([lastSyncAt])
}

// ============================================================
// MEDIA — Photo/document management with S3
// ============================================================

model Media {
  id            String   @id @default(cuid())
  fileName      String
  contentType   String   // image/jpeg, application/pdf, etc.
  fileSize      Int      @default(0) // bytes (0 until confirmed)
  key           String   @unique // S3 object key
  thumbnailKey  String?  // S3 thumbnail key
  cdnUrl        String?  // Public CDN URL

  tenantId      String?
  userId        String
  entityType    String?  // "report", "site", "equipment"
  entityId      String?

  uploadStatus  String   @default("pending") // pending, completed, failed
  isDeleted     Boolean  @default(false)
  deletedAt     DateTime?
  deletedBy     String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([uploadStatus])
  @@index([isDeleted, deletedAt])
}

// ============================================================
// CONFLICT AUDIT — Immutable conflict resolution log
// ============================================================

model ConflictAudit {
  id                  String   @id @default(cuid())
  entityId            String   // Report ID or other entity
  entityType          String   // "report", "pile_work", etc.
  conflictType        String   // "version", "concurrent", "semantic"
  resolutionStrategy  String   // "lww", "server_wins", "field_merge", "vector_clock_merge"
  fieldsInConflict    Json     // ["status", "shiftStart", "piles", ...]
  resolutionDetails   Json     // Full field-level resolution details
  deviceId            String   // Client device that caused conflict
  tenantId            String?
  userId              String?
  clientVersion       Int?
  serverVersion       Int?
  clientVectorClock   Json?
  serverVectorClock   Json?
  createdAt           DateTime @default(now())

  @@index([entityId, createdAt])
  @@index([tenantId, createdAt])
  @@index([deviceId, createdAt])
  @@index([resolutionStrategy])
  @@index([conflictType])
}

// ============================================================
// REFRESH TOKENS — Session management with rotation
// ============================================================

model RefreshToken {
  id            String   @id @default(cuid())
  userId        String
  token         String   @unique // Hashed token
  family        String   // Token family for rotation detection
  expiresAt     DateTime
  revoked       Boolean  @default(false)
  revokedAt     DateTime?
  revokedReason String?
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?
  ipAddress     String?
  userAgent     String?

  @@index([userId])
  @@index([token])
  @@index([family])
  @@index([revoked, expiresAt])
}

// ============================================================
// REPORT PHOTOS — Photo evidence for compliance
// ============================================================

model ReportPhoto {
  id            String   @id @default(cuid())
  reportId      String?
  siteId        String
  tenantId      String?

  // Photo metadata
  fileName      String
  mimeType      String   // image/jpeg, image/png, image/webp
  fileSize      Int      // bytes
  width         Int?
  height        Int?

  // Context
  latitude      Float?
  longitude     Float?
  altitude      Float?
  description   String?  // Optional operator note
  photoType     String   @default("work_evidence") // work_evidence, issue, site_overview

  // Storage
  storagePath   String   // Local file path or S3 key
  thumbnailPath String?  // Thumbnail path
  mediaId       String?  // Link to Media table (optional)

  createdAt     DateTime @default(now())
  createdBy     String?  // User ID who uploaded

  @@index([reportId])
  @@index([siteId])
  @@index([tenantId])
  @@index([createdAt])
  @@index([photoType])
}

// ============================================================
// Dead Letter Queue — permanently failed outbox events
// ============================================================
// Events that exceed MAX_RETRIES in OutboxEvent are moved here for
// manual inspection, retry with debugging, and alerting on persistent
// failures. Separating DLQ from the hot outbox keeps the retry loop
// scanning only live rows.
model DeadLetterQueue {
  id             String   @id @default(cuid())
  eventType      String
  aggregateId    String?
  payload        Json
  errorMessage   String
  attempts       Int      @default(0)
  sourceOutboxId String?
  status         String   @default("pending") // pending | resolved | discarded
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, createdAt])
  @@index([eventType])
  @@index([aggregateId])
}
