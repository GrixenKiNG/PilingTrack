generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/postgres-client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TENANTS — Multi-tenant isolation
// ============================================================

model Tenant {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  isActive    Boolean  @default(true)
  maxUsers    Int      @default(10)
  plan        String   @default("free")

  // Billing & Subscription
  billingEmail String?
  stripeCustomerId String?
  subscriptionStatus String @default("inactive") // inactive, trial, active, past_due, canceled
  trialEndsAt DateTime? @db.Timestamptz(3)
  subscriptionEndsAt DateTime? @db.Timestamptz(3)
  lastBillingAt DateTime? @db.Timestamptz(3)
  monthlyFee    Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("RUB")

  // Usage tracking
  currentUsers  Int      @default(0)
  currentSites  Int      @default(0)
  storageUsedMB Float    @default(0)

  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  users       User[]
  sites       Site[]
  invoices    TenantInvoice[]
  telematicsDevices TelematicsDevice[]

  @@index([slug])
  @@index([isActive])
  @@index([subscriptionStatus])
}

// Tenant Invoices — Billing history
model TenantInvoice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  invoiceNumber String @unique
  periodStart DateTime @db.Timestamptz(3)
  periodEnd   DateTime @db.Timestamptz(3)
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("RUB")
  status      String   @default("pending") // pending, paid, overdue, canceled
  paidAt      DateTime? @db.Timestamptz(3)
  stripeInvoiceId String?

  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(3)

  @@index([tenantId])
  @@index([status])
  @@index([periodStart])
}

// ============================================================
// USERS — 4 roles: ADMIN, DISPATCHER, OPERATOR, ASSISTANT
// ============================================================

model User {
  id         String   @id @default(cuid())
  tenantId   String?
  email      String   @unique
  password   String   @default("")
  // Stores the bcrypt(PIN) — used for the final verify step.
  pin        String?  @unique
  // Deterministic HMAC(PIN, PIN_LOOKUP_SECRET). Used as an O(1) index for
  // PIN auth: look up the single candidate user, then bcrypt-verify against
  // `pin`. Avoids a full table scan on every PIN login.
  pinLookup  String?  @unique
  name       String
  phone      String   @default("")
  role       String   @default("OPERATOR")
  isActive   Boolean  @default(true)
  sessionVersion Int  @default(0)
  timezone   String   @default("Europe/Moscow")

  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @db.Timestamptz(3)

  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  reports    Report[]
  sites      UserSiteAssignment[]
  crew       Crew?    @relation("CrewOperator")
  feedbackReads FeedbackEventRead[]

  @@index([email])
  @@index([tenantId])
}

// ============================================================
// EQUIPMENT PARK
// ============================================================

model Equipment {
  id          String   @id @default(cuid())
  name        String
  model       String   @default("")
  qty         Int      @default(1)
  isActive    Boolean  @default(true)
  tenantId    String
  description String   @default("")

  // A. Identification --------------------------------------------------
  inventoryNumber    String?
  registrationNumber String?         // госномер для самоходных
  kind               EquipmentKind  @default(OTHER)
  baseVehicle        String?         // "Volvo EC360BLC" — носитель для КБУРГа и т.п.
  serialNumber       String?
  manufactureYear    Int?
  vin                String?

  // B. Technical specs (единый шаблон) --------------------------------
  weightTons              Float?
  weightWithEquipmentTons Float?
  // Логистические габариты в миллиметрах
  heightMm                Int?
  lengthMm                Int?
  widthMm                 Int?
  // Двигатель
  engineBrand             String?
  engineSerialNumber      String?
  enginePower             Int?      // кВт
  // Свайные / буровые
  maxPileLength           Float?    // м
  maxDrillingDepth        Float?    // м
  // Молот
  hammerType              String?   // "Junttan HHK-5/7", "PVE 50PR"
  hammerSerialNumber      String?
  hammerEnergyKj          Float?    // кДж
  // Атрибуты сборки чек-листа: подбор блоков МОЛОТ и ВРАЩАТЕЛЬ
  hammerKind              HammerKind @default(NONE)   // гидро / дизель / нет
  isCombined              Boolean    @default(false)  // есть вращатель

  // Устаревшие поля из предыдущей итерации — оставлены чтобы не делать
  // destructive миграцию. UI шаблона их не показывает; удалить отдельной
  // миграцией когда подтвердишь что не нужны.
  heightMeters     Float?
  maxPileDiameter  Int?

  // C. Operation -------------------------------------------------------
  purchaseDate            DateTime? @db.Timestamptz(3)
  purchasePrice           Decimal?  @db.Decimal(14, 2)
  engineHoursTotal        Int?      // суммарная наработка
  nextMaintenanceAtHours  Int?
  nextMaintenanceDate     DateTime? @db.Timestamptz(3)
  homeBaseLocation        String?

  createdAt   DateTime @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @db.Timestamptz(3)

  crews       Crew[]
  reports     Report[] @relation("ReportEquipment")
  deviceKeys  DeviceKey[]
  telematicsDevices       TelematicsDevice[]
  telematicsAssignments   TelematicsDeviceAssignment[]
  documents               EquipmentDocument[]
  maintenanceRecords      MaintenanceRecord[]
  inspections             Inspection[]

  @@index([tenantId])
  @@index([isActive])
  @@index([kind])
  @@index([inventoryNumber])
}

enum EquipmentKind {
  PILE_DRIVER    // забивные копры с молотом
  DRILLING_RIG   // буровые установки
  VIBRO_HAMMER   // вибропогружатели
  HYBRID         // умеющие и забивку, и бурение (Liebherr LRH и т.п.)
  OTHER
}

// Тип молота на установке — управляет подбором блока МОЛОТ чек-листа
enum HammerKind {
  HYDRAULIC   // гидравлический
  DIESEL      // дизельный
  NONE        // молота нет
}

// ============================================================
// EQUIPMENT DOCUMENTS — паспорт, ОТС, страховка, ТО и т.п.
// Файлы хранятся в Media (entityType="equipment"), здесь
// только метаданные документа: тип, срок действия, заметки.
// ============================================================
model EquipmentDocument {
  id          String                 @id @default(cuid())
  tenantId    String
  equipmentId String
  type        EquipmentDocumentType
  title       String                                  // user-facing название документа
  issuedAt    DateTime?              @db.Timestamptz(3)
  expiresAt   DateTime?              @db.Timestamptz(3)
  mediaId     String?                                 // привязка к файлу в Media (опц.)
  notes       String                 @default("")
  createdAt   DateTime               @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime               @updatedAt      @db.Timestamptz(3)

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([equipmentId])
  @@index([type])
  @@index([expiresAt])
}

enum EquipmentDocumentType {
  PASSPORT          // паспорт установки
  OTS               // освидетельствование транспортного средства
  INSURANCE         // страховка ОСАГО / КАСКО / спецтехника
  INSPECTION        // технический осмотр / диагностика
  CERTIFICATE       // сертификат соответствия
  MAINTENANCE_LOG   // журнал ТО / акт ТО
  OTHER
}

// ============================================================
// MAINTENANCE — журнал ТО и ремонтов по установке
// Ручной ввод (диспетчер/админ). Без склада запчастей и workflow
// согласования — это MVP сервисного контура. Стоимость опциональна,
// заложена под будущую аналитику затрат.
// ============================================================
model MaintenanceRecord {
  id          String            @id @default(cuid())
  tenantId    String
  equipmentId String
  type        MaintenanceType
  status      MaintenanceStatus @default(PLANNED)
  title       String
  description String            @default("")
  scheduledAt DateTime?         @db.Timestamptz(3)   // плановая дата
  completedAt DateTime?         @db.Timestamptz(3)   // факт выполнения
  engineHoursAtService Int?                          // моточасы на момент работ
  cost        Decimal?          @db.Decimal(14, 2)   // опц., затраты
  performedBy String?                                // кто выполнил (свободный текст)
  priority    MaintenancePriority @default(NORMAL)   // приоритет наряда
  assigneeId  String?                                // исполнитель (User.id), без relation — как createdById
  startedAt   DateTime?         @db.Timestamptz(3)   // начало работ (для MTTR)
  laborHours  Float?                                 // трудозатраты, ч
  faultCause  String?                                // стадия 1: диагностика / причина отказа
  workDone    String          @default("")           // стадия 2: выполненные работы
  partsUsedText String          @default("")          // израсходованные запчасти текстом ("крючок" под склад)
  closedById  String?                                // кто проверил/закрыл (User.id)
  acceptedById String?                               // кто принял работу (админ, User.id)
  acceptedAt  DateTime?         @db.Timestamptz(3)    // когда принято
  createdById String?
  createdAt   DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime          @updatedAt      @db.Timestamptz(3)

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  inspection  Inspection?   // заполненный чек-лист для записей ЕО/ТО (1:1)

  @@index([tenantId])
  @@index([equipmentId])
  @@index([status])
  @@index([scheduledAt])
  @@index([assigneeId])
  @@index([priority])
}

enum MaintenanceType {
  // Уровни ТО (с собранным чек-листом):
  EO           // ежедневный осмотр и обслуживание
  TO1          // плановое ТО-1
  TO2          // плановое ТО-2
  TO3          // плановое ТО-3
  SEASONAL     // сезонное ТО
  // Свободный ввод:
  REPAIR       // ремонт
  FAULT        // неисправность
  // Deprecated — оставлены ради недеструктивной миграции; новые записи не создаём:
  SCHEDULED    // (≈ TO1)
  INSPECTION   // (≈ EO)
}

enum MaintenanceStatus {
  PLANNED
  ASSIGNED
  IN_PROGRESS
  ON_HOLD
  DONE
  CANCELLED
}

enum MaintenancePriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// ============================================================
// INSPECTIONS — Checklist engine (ЕО/ТО)
// ============================================================

enum ChecklistLevel {
  EO
  TO1
  TO2
  TO3
  SEASONAL
}

enum AnswerType {
  YES_NO
  STATUS4
  DONE
  MEASURE
}

enum InspectionStatus {
  DRAFT
  COMPLETED
}

enum BlockType {
  BASE     // база установки (по марке/модели)
  HAMMER   // блок молота (по типу молота)
  ROTARY   // блок вращателя (для комбинированных)
}

model ChecklistTemplate {
  id                  String         @id @default(cuid())
  tenantId            String
  name                String
  level               ChecklistLevel
  blockType           BlockType      @default(BASE)
  appliesToModel      String?        // для BASE-блоков: марка/модель
  appliesToHammerKind HammerKind?    // для HAMMER-блоков: тип молота
  isActive            Boolean        @default(true)
  createdById         String?
  createdAt           DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime       @updatedAt      @db.Timestamptz(3)
  sections            ChecklistSection[]
  inspections         Inspection[]
  @@index([tenantId])
  @@index([tenantId, level])
  @@index([tenantId, blockType, level])
}

model ChecklistSection {
  id         String @id @default(cuid())
  tenantId   String
  templateId String
  title      String
  order      Int
  items      ChecklistItem[]
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([templateId])
}

model ChecklistItem {
  id            String     @id @default(cuid())
  tenantId      String
  sectionId     String
  text          String
  answerType    AnswerType @default(YES_NO)
  unit          String?
  norm          String?
  provenance    String?
  photoRequired Boolean    @default(false)
  required      Boolean    @default(true)
  order         Int
  section       ChecklistSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([sectionId])
}

model Inspection {
  id                  String   @id @default(cuid())
  tenantId            String
  equipmentId         String
  templateId          String
  maintenanceRecordId String?  @unique   // 1:1 с записью ТО (ЕО/ТО)
  level            ChecklistLevel
  performedById    String
  shift            String?
  inspectionDate   DateTime @db.Timestamptz(3)
  engineHours      Int?
  healthScore      Int?
  status           InspectionStatus @default(DRAFT)
  templateSnapshot Json
  signedByName     String?
  signedAt         DateTime? @db.Timestamptz(3)
  createdAt        DateTime @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime @updatedAt      @db.Timestamptz(3)
  answers          InspectionAnswer[]
  equipment        Equipment        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  template         ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  maintenanceRecord MaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: SetNull)
  @@index([tenantId])
  @@index([tenantId, equipmentId])
  @@index([tenantId, status])
}

model InspectionAnswer {
  id           String @id @default(cuid())
  tenantId     String
  inspectionId String
  itemId       String
  result       String
  value        String?
  note         String?
  photoCount   Int    @default(0)
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([inspectionId])
}

// ============================================================
// DEVICE KEYS — IoT telemetry authentication
// Plaintext key is shown to the operator exactly once at provisioning
// and never stored; only `keyHash` (HMAC-SHA256 with DEVICE_KEY_LOOKUP_SECRET)
// is persisted, so DB read access alone cannot impersonate a device.
// ============================================================
model DeviceKey {
  id           String   @id @default(cuid())
  keyHash      String   @unique
  name         String   // operator-facing label (e.g. "Rig 4 — North site MQTT")
  tenantId     String?
  equipmentId  String
  siteId       String?
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  createdById  String?
  lastUsedAt   DateTime? @db.Timestamptz(3)

  // Опциональная ссылка на физическое/виртуальное устройство.
  // Для PUSH-боксов (Teltonika и пр.) один TelematicsDevice → один-два
  // активных DeviceKey (текущий + переходный при ротации).
  telematicsDeviceId String?

  equipment        Equipment         @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  telematicsDevice TelematicsDevice? @relation(fields: [telematicsDeviceId], references: [id], onDelete: SetNull)

  @@index([equipmentId])
  @@index([tenantId])
  @@index([revoked])
  @@index([telematicsDeviceId])
}

// ============================================================
// TELEMATICS DEVICE — точка телеметрии на машине
// ------------------------------------------------------------
// Один device = одна "точка съёма данных". Это может быть:
//   PUSH — физический бокс (Teltonika FMC640, Galileosky 7x),
//          шлёт данные нам по HTTP/MQTT; авторизация через DeviceKey.
//   PULL — виртуальный коннектор к OEM API (LiDAT, Volvo CareTrack...),
//          мы поллим их облако. Поллер появится позже; поля
//          (endpointUrl, pollIntervalSec, lastPolledAt, nextPollAt)
//          уже заведены — БД готова, миграции не понадобится.
//
// Жизненный цикл status:
//   PROVISIONED → ACTIVE → DEGRADED → OFFLINE → ARCHIVED
// ============================================================
model TelematicsDevice {
  id              String   @id @default(cuid())
  tenantId        String

  provider        TelematicsProvider
  model           String?            // субмодель: "FMC640", "Hiper VR"
  firmwareVersion String?

  imei            String?            // для cellular-боксов
  serialNumber    String?
  oemAccountId    String?            // ID в Wialon / Volvo CareTrack и т.п.

  authType        TelematicsAuthType

  // Зарезервировано для PULL-режима. Сейчас все строки = NULL.
  endpointUrl     String?
  pollIntervalSec Int?
  lastPolledAt    DateTime?          @db.Timestamptz(3)
  nextPollAt      DateTime?          @db.Timestamptz(3)

  equipmentId     String?
  installedAt     DateTime?          @db.Timestamptz(3)

  status          TelematicsStatus   @default(PROVISIONED)
  lastSeenAt      DateTime?          @db.Timestamptz(3)
  lastError       String?

  label           String             // operator-facing: "Бауман-100 (FMC640)"
  notes           String             @default("")
  createdAt       DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime           @updatedAt @db.Timestamptz(3)

  equipment       Equipment?         @relation(fields: [equipmentId], references: [id], onDelete: SetNull)
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  deviceKeys      DeviceKey[]
  assignments     TelematicsDeviceAssignment[]

  @@index([tenantId])
  @@index([equipmentId])
  @@index([provider])
  @@index([status])
  @@index([nextPollAt])
  @@unique([provider, imei], map: "uq_telematics_provider_imei")
}

enum TelematicsProvider {
  TELTONIKA_FMC640
  TELTONIKA_FMB640
  GALILEOSKY_7X
  WIALON_GENERIC
  OTHER
}

enum TelematicsAuthType {
  PUSH_TOKEN     // device пушит к нам, авторизация через DeviceKey
  API_KEY        // зарезервировано (PULL)
  OAUTH2         // зарезервировано (PULL)
  IP_ALLOWLIST   // зарезервировано
  NONE
}

enum TelematicsStatus {
  PROVISIONED
  ACTIVE
  DEGRADED
  OFFLINE
  ARCHIVED
}

// ============================================================
// TELEMATICS DEVICE ASSIGNMENT — append-only история привязок
// ------------------------------------------------------------
// "Teltonika #FMC-1234 стояла на LRH 100 №1 с 2026-05-17
//  по 2026-09-15, потом перенесена на Banut 655."
// Нужен для аудита ("чьи это данные были по той свае?")
// и для замен боксов в эксплуатации.
// ============================================================
model TelematicsDeviceAssignment {
  id          String    @id @default(cuid())
  tenantId    String
  deviceId    String
  equipmentId String
  startedAt   DateTime  @default(now()) @db.Timestamptz(3)
  endedAt     DateTime? @db.Timestamptz(3)  // NULL = текущая активная
  reason      String?                        // "first install", "swap to rig-7"

  device      TelematicsDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  equipment   Equipment        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([deviceId, startedAt])
  @@index([equipmentId, startedAt])
  @@index([tenantId])
}

// ============================================================
// SITES
// ============================================================

model Site {
  id               String    @id @default(cuid())
  tenantId         String?
  name             String
  isActive         Boolean   @default(true)
  plannedPiles     Int       @default(0)
  plannedDrilling  Float     @default(0)
  status           String    @default("ACTIVE")
  completionDate   DateTime? @db.Timestamptz(3)

  createdAt        DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(3)

  tenant           Tenant?   @relation(fields: [tenantId], references: [id])
  fields           PileField[]
  pilePlans        SitePilePlan[]
  drillingPlans    SiteDrillingPlan[]
  users            UserSiteAssignment[]
  reports          Report[]
  crews            Crew[]

  @@index([tenantId])
  @@index([isActive])
  @@index([tenantId, isActive])
}

// Site pile plan: grade → count × meters per unit → auto total meters
model SitePilePlan {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pileGradeId   String
  pileGrade     PileGrade @relation(fields: [pileGradeId], references: [id], onDelete: Cascade)
  count         Int      @default(0)
  metersPerUnit Float    @default(0)

  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  @@index([siteId])
  @@index([pileGradeId])
}

// Site drilling plan: diameter → count × meters per unit → auto total meters
model SiteDrillingPlan {
  id            String   @id @default(cuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  diameter      Float    @default(0)
  count         Int      @default(0)
  metersPerUnit Float    @default(0)

  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  @@index([siteId])
}

model PileField {
  id        String   @id @default(cuid())
  name      String
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  clusters  Cluster[]

  @@index([siteId])
}

model Cluster {
  id        String   @id @default(cuid())
  name      String
  fieldId   String
  field     PileField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  pickets   Picket[]

  @@index([fieldId])
}

model Picket {
  id        String   @id @default(cuid())
  name      String
  clusterId String
  cluster   Cluster  @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  piles     PileWork[]
  drillings LeaderDrilling[]

  @@index([clusterId])
}

// ============================================================
// CREWS — with named assistants
// ============================================================

model Crew {
  id              String   @id @default(cuid())
  name            String   @default("")
  isActive        Boolean  @default(true)
  operatorId      String   @unique
  equipmentId     String
  siteId          String

  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @db.Timestamptz(3)

  operator        User       @relation("CrewOperator", fields: [operatorId], references: [id], onDelete: Cascade)
  equipment       Equipment @relation(fields: [equipmentId], references: [id], onDelete: Restrict)
